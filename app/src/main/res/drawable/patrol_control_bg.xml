<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#343021" />
            <stroke android:width="1dp" android:color="#C6B57B" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#151A17" />
            <stroke android:width="1dp" android:color="#3A433E" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
